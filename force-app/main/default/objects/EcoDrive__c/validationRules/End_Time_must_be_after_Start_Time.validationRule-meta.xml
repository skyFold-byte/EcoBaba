<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>End_Time_must_be_after_Start_Time</fullName>
    <active>true</active>
    <description>End Time must be after Start Time.</description>
    <errorConditionFormula>End_Time__c &lt; Start_Time__c</errorConditionFormula>
    <errorDisplayField>End_Time__c</errorDisplayField>
    <errorMessage>End Time must be after Start Time.</errorMessage>
</ValidationRule>
